# Database (choose one)

# DuckDB (local, recommended for starters)
DATABASE_URL="duckdb:///tomos_memory.duckdb"

# PostgreSQL with pgvector
# DATABASE_URL="postgresql://user:pass@localhost:5432/tomos"

# Embedding service (choose one)

# LM Studio (local, recommended)
LM_STUDIO_URL="http://localhost:1234/v1"
LM_STUDIO_EMBED_MODEL="nomic-embed-text"

# Ollama (local)
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_EMBED_MODEL="nomic-embed-text"

# OpenAI (cloud)
# OPENAI_API_KEY="sk-..."
# OPENAI_EMBED_MODEL="text-embedding-3-small"

# Optional: Discord alerts
# DISCORD_MEMORY_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# Optional: Custom paths
# TOMOS_REPO_MEMORY_PATH="/path/to/repo"
# TOMOS_MEMORY_POLICY_PATH="./memory-layer/index-policy.json"
